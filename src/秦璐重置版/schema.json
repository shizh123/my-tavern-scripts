{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "世界": {
      "default": {},
      "type": "object",
      "properties": {
        "时间": {
          "default": "夜晚",
          "description": "仅氛围显示，AI 自由维护，脚本不参与计算",
          "$ref": "#/$defs/__schema0"
        },
        "日期": {
          "default": "2024/11/20",
          "description": "仅氛围显示，AI 自由维护",
          "$ref": "#/$defs/__schema1"
        },
        "地点": {
          "default": "家 - 客厅",
          "type": "string"
        },
        "环境氛围": {
          "default": "日常",
          "description": "场景氛围：日常/暧昧/紧张/情色/剑拔弩张等",
          "$ref": "#/$defs/__schema2"
        }
      }
    },
    "秦璐状态": {
      "default": {},
      "type": "object",
      "properties": {
        "沦陷度": {
          "default": 0,
          "type": "number"
        },
        "对主角依存度": {
          "default": 5,
          "type": "number"
        },
        "对苏文依存度": {
          "default": 0,
          "type": "number"
        },
        "当前阶段": {
          "default": 1,
          "type": "number"
        },
        "阶段标题": {
          "default": "掌控",
          "type": "string",
          "enum": [
            "掌控",
            "动摇",
            "陷落",
            "臣服"
          ]
        },
        "当前心理想法": {
          "default": "交易所下个月的拍卖名单该定了。{{user}}最近的训练可以加点料——他太顺了。",
          "description": "80-150字第一人称内心独白，AI 每轮更新。必须冷、锋利、自我意识清晰",
          "$ref": "#/$defs/__schema3"
        },
        "当前情绪": {
          "default": "冷静",
          "type": "string"
        },
        "当前位置": {
          "default": "客厅",
          "$ref": "#/$defs/__schema4"
        },
        "服装细节": {
          "default": {},
          "type": "object",
          "properties": {
            "头部": {
              "default": "无",
              "description": "发饰、头饰等",
              "$ref": "#/$defs/__schema5"
            },
            "上装": {
              "default": "黑色丝绸衬衫，领口解开两颗扣子",
              "type": "string"
            },
            "下装": {
              "default": "烟灰色高腰西裤",
              "type": "string"
            },
            "内衣": {
              "default": {},
              "type": "object",
              "properties": {
                "上": {
                  "default": "黑色蕾丝无钢圈文胸",
                  "type": "string"
                },
                "下": {
                  "default": "黑色蕾丝丁字裤",
                  "type": "string"
                }
              }
            },
            "袜裤": {
              "default": "无",
              "type": "string"
            },
            "鞋子": {
              "default": "室内绒面拖鞋",
              "type": "string"
            },
            "外套": {
              "default": "无",
              "description": "大衣、披肩等",
              "$ref": "#/$defs/__schema6"
            },
            "配饰": {
              "default": "婚戒、珍珠耳钉",
              "description": "首饰、手表等",
              "$ref": "#/$defs/__schema7"
            },
            "特殊装饰": {
              "default": "左手腕一道极淡的旧疤痕",
              "description": "项圈、手铐等",
              "$ref": "#/$defs/__schema8"
            },
            "整体风格": {
              "default": "居家但精致的冷艳",
              "type": "string"
            },
            "暴露程度": {
              "default": "正常",
              "type": "string",
              "enum": [
                "保守",
                "正常",
                "清凉",
                "暴露",
                "极度暴露"
              ]
            },
            "整洁度": {
              "default": "一丝不苟",
              "type": "string",
              "enum": [
                "整洁",
                "略显凌乱",
                "凌乱",
                "破损",
                "衣不蔽体"
              ]
            }
          }
        },
        "妆容细节": {
          "default": {},
          "type": "object",
          "properties": {
            "底妆": {
              "default": "轻薄粉底，自然肤色",
              "type": "string"
            },
            "眼妆": {
              "default": "淡棕色眼影，极细眼线",
              "type": "string"
            },
            "唇妆": {
              "default": "豆沙色哑光唇釉",
              "type": "string"
            },
            "腮红": {
              "default": "自然修容",
              "type": "string"
            },
            "特殊妆容": {
              "default": "无",
              "description": "纹身妆、泪痕妆等",
              "$ref": "#/$defs/__schema9"
            },
            "香氛": {
              "default": "淡淡的檀木与白麝香",
              "description": "香水气息",
              "$ref": "#/$defs/__schema10"
            },
            "整体风格": {
              "default": "冷艳精致",
              "type": "string"
            },
            "浓淡程度": {
              "default": "淡妆",
              "type": "string",
              "enum": [
                "素颜",
                "淡妆",
                "日常妆",
                "浓妆",
                "艳妆"
              ]
            }
          }
        },
        "身体改造": {
          "default": {},
          "type": "object",
          "properties": {
            "纹身": {
              "description": "部位: 纹身内容",
              "default": {},
              "$ref": "#/$defs/__schema11"
            },
            "穿刺": {
              "default": {},
              "type": "object",
              "properties": {
                "耳环": {
                  "default": false,
                  "type": "boolean"
                },
                "乳环": {
                  "default": false,
                  "type": "boolean"
                },
                "乳头环": {
                  "default": false,
                  "type": "boolean"
                },
                "阴蒂环": {
                  "default": false,
                  "type": "boolean"
                },
                "舌环": {
                  "default": false,
                  "type": "boolean"
                },
                "肚脐环": {
                  "default": false,
                  "type": "boolean"
                },
                "阴唇环": {
                  "default": false,
                  "type": "boolean"
                },
                "其他": {
                  "default": [],
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            },
            "乳晕改造": {
              "default": "无",
              "description": "如：增大、变色、穿刺等",
              "$ref": "#/$defs/__schema12"
            },
            "永久标记": {
              "default": [],
              "description": "烙印、伤疤等",
              "$ref": "#/$defs/__schema13"
            },
            "临时标记": {
              "default": [],
              "description": "吻痕、精液痕迹等",
              "$ref": "#/$defs/__schema14"
            },
            "体态变化": {
              "default": "无",
              "description": "因开发导致的身体变化",
              "$ref": "#/$defs/__schema15"
            }
          }
