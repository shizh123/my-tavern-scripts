          "default": {},
          "type": "object",
          "properties": {
            "待触发": {
              "default": false,
              "description": "是否有待触发的巡逻事件",
              "$ref": "#/$defs/__schema48"
            },
            "已通知AI": {
              "default": false,
              "description": "是否已通过系统消息通知AI",
              "$ref": "#/$defs/__schema49"
            },
            "触发时间": {
              "default": "",
              "description": "巡逻触发的时间",
              "$ref": "#/$defs/__schema50"
            },
            "巡逻位置": {
              "default": "",
              "description": "苏文巡逻经过的位置",
              "$ref": "#/$defs/__schema51"
            },
            "上次巡逻时间": {
              "default": "",
              "description": "上次巡逻触发的时间，用于冷却",
              "$ref": "#/$defs/__schema52"
            },
            "离开期限": {
              "default": "",
              "description": "苏文要求离开的截止时间，格式: HH:mm",
              "$ref": "#/$defs/__schema53"
            },
            "期限小时数": {
              "default": 0,
              "description": "苏文设置的离开期限小时数（1-2小时）",
              "$ref": "#/$defs/__schema54"
            }
