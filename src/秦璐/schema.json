                }
              }
            },
            "乳晕改造": {
              "default": "无",
              "description": "如：增大、变色、穿刺等",
              "$ref": "#/$defs/__schema11"
            },
            "永久标记": {
              "default": [],
              "description": "烙印、伤疤等",
              "$ref": "#/$defs/__schema12"
            },
            "临时标记": {
              "default": [],
              "description": "吻痕、精液痕迹等",
              "$ref": "#/$defs/__schema13"
            },
            "体态变化": {
              "default": "无",
              "description": "因开发导致的身体变化",
              "$ref": "#/$defs/__schema14"
            }
          }
        },
        "气质描述": {
          "default": "温柔贤淑的家庭主妇",
          "type": "string"
        },
        "习惯列表": {
          "default": [],
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "内容": {
                "type": "string",
                "description": "具体的行为或思维模式"
              },
              "形成时间": {
                "type": "string",
                "description": "格式: YYYY/MM/DD HH:mm"
              }
            },
            "required": [
              "内容",
              "形成时间"
            ]
          }
        },
        "念头培育区": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "念头内容": {
                "type": "string"
              },
              "植入时间": {
                "type": "string",
                "description": "格式: YYYY/MM/DD HH:mm"
              },
              "过期时间": {
                "type": "string",
                "description": "植入时间+24h"
              },
              "需要时间": {
                "type": "number",
                "description": "3-5小时，根据难度计算；待判定时为0"
              },
              "难度等级": {
                "default": "中等",
                "type": "string",
                "enum": [
                  "简单",
                  "中等",
                  "困难",
                  "待定"
                ]
              },
              "开发进度": {
                "default": 0,
                "description": "累积的相关互动时间（小时）",
                "$ref": "#/$defs/__schema15"
              },
              "待判定": {
                "default": false,
                "description": "本地无法匹配类型时为true，等待AI判定",
                "$ref": "#/$defs/__schema16"
              }
            },
            "required": [
              "念头内容",
              "植入时间",
              "过期时间",
              "需要时间"
            ]
          }
        }
      }
