          "default": [],
          "description": "记录待通知AI的念头植入操作",
          "$ref": "#/$defs/__schema55"
        },
        "强制事件日志": {
          "default": [],
          "description": "记录待通知AI的强制事件",
          "$ref": "#/$defs/__schema57"
        }
