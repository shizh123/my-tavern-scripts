        "苏梦危险时间累计": {
          "default": 0,
          "description": "苏梦在主角房间且苏文在家清醒的累计小时数",
          "$ref": "#/$defs/__schema37"
        },
        "秦璐外观待更新": {
          "default": {},
          "$ref": "#/$defs/__schema38"
        },
        "苏梦外观待更新": {
          "default": {},
          "$ref": "#/$defs/__schema38"
        },
