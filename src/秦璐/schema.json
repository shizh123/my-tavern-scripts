            },
            "生效开始时间": {
              "default": "",
              "description": "安眠药开始生效的时间，格式: YYYY/MM/DD HH:mm",
              "$ref": "#/$defs/__schema19"
            },
            "生效结束时间": {
              "default": "",
              "description": "安眠药失效的时间（6小时后），格式: YYYY/MM/DD HH:mm",
              "$ref": "#/$defs/__schema20"
            },
            "剩余时间": {
              "default": 0,
              "description": "剩余生效时间（小时）",
              "$ref": "#/$defs/__schema21"
            },
            "上次使用时间": {
              "default": "",
              "description": "上次使用安眠药的时间，用于48小时冷却判定",
