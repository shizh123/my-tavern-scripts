        "当前情绪": {
          "default": "疲惫",
          "type": "string"
        },
        "当前心理想法": {
          "default": "今天的董事会又被她抢了话。算了——争不过。{{user}}最近好像和她走得更近了……应该是我的错觉。",
          "description": "AI 每轮更新，不论在不在场。被瞒在鼓里的丈夫视角，对家中微妙变化的感知与自我解释",
          "$ref": "#/$defs/__schema19"
        },
        "对秦璐疑心值": {
          "default": 0,
          "type": "number"
        },
        "对秦璐疑心值冻结": {
          "default": {},
          "type": "object",
          "properties": {
            "是否冻结": {
              "default": false,
              "type": "boolean"
            },
            "借口内容": {
              "default": "",
              "type": "string"
            },
            "冻结结束楼层": {
              "default": -1,
              "description": "当前楼层 >= 此值则解冻",
              "$ref": "#/$defs/__schema20"
            }
          }
        }
      }
    },
    "系统": {
      "default": {},
      "type": "object",
      "properties": {
        "货币": {
          "default": 0,
          "type": "number"
        },
        "道具状态": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "string",
            "enum": [
              "未购买",
              "已购买",
              "使用中"
            ]
          }
        },
        "当前角色": {
          "default": "秦璐",
          "type": "string",
          "enum": [
            "秦璐"
          ]
        },
        "在场角色": {
          "default": {},
          "type": "object",
          "properties": {
            "秦璐": {
              "default": true,
              "type": "boolean"
            }
          }
        },
        "念头植入日志": {
          "default": [],
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "目标": {
                "type": "string",
                "enum": [
                  "秦璐"
                ]
              },
              "念头ID": {
                "type": "string"
              },
              "内容": {
                "type": "string"
              },
              "植入楼层": {
                "type": "number"
              },
              "已通知AI": {
                "default": false,
                "type": "boolean"
              }
            },
            "required": [
              "目标",
              "念头ID",
              "内容",
              "植入楼层"
            ]
          }
        },
        "本轮相关念头": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "default": 0,
            "type": "number"
          }
        },
        "_待发送道具事件": {
          "default": "",
          "type": "string"
        },
        "_苏文作息游标": {
          "default": 0,
          "type": "number"
        },
        "_上次处理楼层": {
          "default": -1,
          "type": "number"
        },
        "_在场锁定": {
          "default": false,
          "type": "boolean"
        }
      }
    }
  },
