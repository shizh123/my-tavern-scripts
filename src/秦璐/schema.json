          "properties": {
            "待触发": {
              "default": false,
              "description": "是否有待触发的打断事件",
              "$ref": "#/$defs/__schema42"
            },
            "已通知AI": {
              "default": false,
              "description": "是否已通过系统消息通知AI",
              "$ref": "#/$defs/__schema43"
            },
            "打断原因": {
              "default": "",
              "description": "如：在主角房间停留过久",
              "$ref": "#/$defs/__schema44"
            },
            "累计时间": {
              "default": 0,
              "description": "触发打断时的累计危险时间",
              "$ref": "#/$defs/__schema45"
