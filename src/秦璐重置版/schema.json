                "$ref": "#/$defs/__schema16"
              },
              "状态": {
                "default": "判定中",
                "type": "string",
                "enum": [
                  "判定中",
                  "培育中",
                  "未达标",
                  "已成熟",
                  "已过期"
                ]
              },
              "难度": {
                "default": "待定",
                "type": "string",
                "enum": [
                  "简单",
                  "困难",
                  "待定"
                ]
              },
              "需要楼数": {
                "default": 0,
                "description": "成熟所需楼层数，类型判定后由脚本按难度设定",
                "$ref": "#/$defs/__schema17"
              },
              "开发进度": {
                "default": 0,
                "description": "累积楼层进度（含加速）",
                "$ref": "#/$defs/__schema18"
              },
              "植入楼层": {
                "default": -1,
                "type": "number"
              }
            },
            "required": [
              "内容"
            ]
          }
        },
        "习惯列表": {
          "default": [],
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "内容": {
                "type": "string",
                "description": "已固化的行为/思维"
              },
              "形成楼层": {
                "default": -1,
                "type": "number"
              }
            },
            "required": [
              "内容"
            ]
          }
        }
      }
