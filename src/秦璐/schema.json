          "default": 0,
          "description": "【已废弃】兼容旧数据，新逻辑使用角色独立的危险时间累计",
          "$ref": "#/$defs/__schema35"
        },
        "秦璐危险时间累计": {
          "default": 0,
          "description": "秦璐在主角房间且苏文在家清醒的累计小时数",
          "$ref": "#/$defs/__schema36"
