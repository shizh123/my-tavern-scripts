              "properties": {
                "上": {
                  "default": "肉色棉质文胸",
                  "type": "string"
                },
                "下": {
                  "default": "棉质内裤",
                  "type": "string"
                }
              }
            },
            "袜裤": {
              "default": "肉色丝袜",
              "type": "string"
            },
            "鞋子": {
              "default": "室内拖鞋",
              "type": "string"
            },
            "外套": {
              "default": "无",
              "description": "大衣、披肩等",
              "$ref": "#/$defs/__schema6"
            },
