              "enum": [
                "保守",
                "正常",
                "清凉",
                "暴露",
                "极度暴露"
              ]
            },
            "整洁度": {
              "default": "整洁",
              "type": "string",
              "enum": [
                "整洁",
                "略显凌乱",
                "凌乱",
                "破损",
                "衣不蔽体"
              ]
            }
          }
        },
