            "剩余天数": {
              "default": 0,
              "description": "剩余住院天数",
              "$ref": "#/$defs/__schema27"
            },
            "触发楼层": {
              "default": -1,
              "description": "触发住院的消息楼层ID，用于ROLL时判断是否重复触发",
              "$ref": "#/$defs/__schema28"
