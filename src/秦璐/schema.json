              "$ref": "#/$defs/__schema10"
            },
            "穿刺": {
              "default": {},
              "type": "object",
              "properties": {
                "耳环": {
                  "default": false,
                  "type": "boolean"
                },
                "乳环": {
                  "default": false,
                  "type": "boolean"
                },
                "乳头环": {
                  "default": false,
                  "type": "boolean"
                },
                "阴蒂环": {
                  "default": false,
                  "type": "boolean"
                },
                "舌环": {
                  "default": false,
                  "type": "boolean"
                },
                "肚脐环": {
                  "default": false,
                  "type": "boolean"
                },
                "阴唇环": {
                  "default": false,
                  "type": "boolean"
                },
                "其他": {
                  "default": [],
