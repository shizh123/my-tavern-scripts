// 苏文印象自动更新：根据疑心值自动更新苏文对秦璐和苏梦的印象

$(async () => {
  await waitGlobalInitialized('Mvu');

  console.info('[苏文印象更新脚本] 开始加载');

  /**
   * 根据疑心值获取对秦璐的印象
   * 每5点疑心值一个阶段，共20个阶段
   */
  function getQinluImpression(suspicion: number): string {
    const stage = Math.floor(suspicion / 5);

    const impressions = [
      '我的贤内助', // 0-4
      '温柔体贴的老婆', // 5-9
      '还是老样子', // 10-14
      '她最近有点心不在焉', // 15-19
      '她行为有些反常', // 20-24
      '她心思不知在哪', // 25-29
      '她在隐瞒什么', // 30-34
      '她肯定有事瞒着我', // 35-39
      '她的举止让我不安', // 40-44
      '她在背着我做什么？', // 45-49
      '她行为很可疑', // 50-54
      '她一定有问题', // 55-59
      '她肯定背着我干了什么', // 60-64
      '她在骗我', // 65-69
      '她背叛了我的信任', // 70-74
      '她可能背叛了我', // 75-79
      '她肯定出轨了', // 80-84
      '这个不忠的女人', // 85-89
      '她彻底变了', // 90-94
      '她已经不是我认识的那个人了', // 95-100
    ];

    return impressions[Math.min(stage, 19)] || impressions[19];
  }

  /**
   * 根据疑心值获取对苏梦的印象
   * 每5点疑心值一个阶段，共20个阶段
   */
  function getSumengImpression(suspicion: number): string {
    const stage = Math.floor(suspicion / 5);

    const impressions = [
      '我的乖女儿', // 0-4
      '懂事的好孩子', // 5-9
      '还挺听话的', // 10-14
      '她最近有点心不在焉', // 15-19
      '她行为有些反常', // 20-24
      '她心思不知在哪', // 25-29
      '她在隐瞒什么', // 30-34
      '她肯定有事瞒着我', // 35-39
      '她的举止让我担心', // 40-44
      '她在背着我做什么？', // 45-49
      '她行为很可疑', // 50-54
      '她一定有问题', // 55-59
      '她肯定背着我干了什么', // 60-64
      '她在骗我', // 65-69
      '她背叛了我的信任', // 70-74
      '她是不是学坏了', // 75-79
      '她肯定学坏了', // 80-84
      '这孩子被带坏了', // 85-89
      '她彻底变了', // 90-94
      '她已经不是我认识的那个孩子了', // 95-100
    ];

    return impressions[Math.min(stage, 19)] || impressions[19];
  }

  /**
   * 更新苏文的印象
   */
  function updateSuwenImpressions() {
    updateVariablesWith(
      vars => {
        const data = _.get(vars, 'stat_data');

        // 获取疑心值
        const qinluSuspicion = data.苏文状态.对秦璐疑心值;
        const sumengSuspicion = data.苏文状态.对苏梦疑心值;

        // 计算新的印象
        const newQinluImpression = getQinluImpression(qinluSuspicion);
        const newSumengImpression = getSumengImpression(sumengSuspicion);

        // 检查是否需要更新
        let hasChanges = false;

        if (data.苏文状态.对秦璐印象 !== newQinluImpression) {
          console.info(
            `[苏文印象] 秦璐印象更新: "${data.苏文状态.对秦璐印象}" → "${newQinluImpression}" (疑心值: ${qinluSuspicion})`,
          );
          data.苏文状态.对秦璐印象 = newQinluImpression;
          hasChanges = true;
        }

        if (data.苏文状态.对苏梦印象 !== newSumengImpression) {
          console.info(
            `[苏文印象] 苏梦印象更新: "${data.苏文状态.对苏梦印象}" → "${newSumengImpression}" (疑心值: ${sumengSuspicion})`,
          );
          data.苏文状态.对苏梦印象 = newSumengImpression;
          hasChanges = true;
        }

        if (hasChanges) {
          console.info('[苏文印象] 印象已更新');
        }

        return vars;
      },
      { type: 'message', message_id: -1 },
    );
  }

  // 监听AI消息接收完成事件
  eventOn(tavern_events.MESSAGE_RECEIVED, () => {
    console.info('[苏文印象] MESSAGE_RECEIVED 事件触发');
    // 【重要】延迟1100ms执行，确保在念头成熟检测(800ms+写入)完成之后执行
    // 执行顺序: 时间推进(300ms+写入) → 念头成熟检测(800ms+写入) → 苏文印象更新(1100ms) → 阶段外观更新(1400ms) → 界面刷新(1800ms)
    setTimeout(() => {
      console.info('[苏文印象] 开始更新苏文印象...');
      try {
        updateSuwenImpressions();
        console.info('[苏文印象] 更新完成');
      } catch (err) {
        console.error('[苏文印象] 更新时发生错误:', err);
      }
    }, 1100);
  });

  console.info('[苏文印象更新脚本] 加载完成，事件监听已注册');
});
