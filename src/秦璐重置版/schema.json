          "default": "冷艳危险的豪门主母，苏秦集团暗面女王",
          "type": "string"
        },
        "念头列表": {
          "default": {},
          "type": "object",
          "propertyNames": {
            "type": "string"
          },
          "additionalProperties": {
            "type": "object",
            "properties": {
              "内容": {
                "type": "string",
                "description": "玩家输入原文，AI 不要修改"
              },
              "类型": {
                "default": "待判定",
